# Market Data
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# News
NEWSAPI_KEY=your_newsapi_key
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# LLM Providers (all optional - VADER works without any)
# Copilot provider uses GitHub device-flow auth (no key needed here)
GROQ_API_KEY=your_groq_key
OPENAI_API_KEY=your_openai_key

# App Config
DATABASE_URL=sqlite:///./quantsense.db
PAPER_TRADING_INITIAL_CASH=100000
SENTIMENT_REFRESH_MINUTES=30

# Notifications (Optional)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Broker (Optional - for real trading)
ALPACA_API_KEY=your_alpaca_key
ALPACA_SECRET_KEY=your_alpaca_secret
ALPACA_PAPER=True

# Security
WEBHOOK_SECRET=generate_a_secure_random_key_here
